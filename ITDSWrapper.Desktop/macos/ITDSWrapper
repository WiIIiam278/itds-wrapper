#!/bin/sh

DIR=$(dirname "$0")
ARM64=$(sysctl -ni hw.optional.arm64)

if [[ "$ARM64" == 1 ]]; then
    exec "ITDS_PATH=\"$DIR/Into the Dream Spring.ARM64.app\" open $DIR/SteamworksHelper.ARM64.app"
else
    exec "ITDS_PATH=\"$DIR/Into the Dream Spring.X64.app\" open $DIR/SteamworksHelper.X64.app"
fi